# ───────────── Build output ─────────────
target/
dist/
*.jar
*.war

# ───────────── IDE / editors ─────────────
.idea/
*.iml
.vscode/
*.swp
*~

# ───────────── Logs ─────────────
*.log
logs/

# ───────────── Secrets / certificates (DO NOT COMMIT) ─────────────
# Self-signed keystore generated by start-https.bat
orbion.p12
*.p12
*.jks
*.keystore
*.pem
*.key
# Local environment overrides – real secrets stay out of git...
.env
.env.*
# ...but the committed template must remain tracked.
!.env.example

# Local / secret Spring property overrides (machine-specific).
# The base application.properties / application-https.properties ARE committed
# (they hold config, no secrets). Only personal override files are ignored:
application-local.properties
application-secret.properties
application-*.local.properties
*-secret.properties

# ───────────── OS files ─────────────
.DS_Store
Thumbs.db
desktop.ini
