# Orbion environment configuration — EXAMPLE
#
# Copy this file to ".env" and adjust the values, OR simply export these as
# real environment variables before launching Orbion. Spring Boot reads
# operating-system environment variables directly (e.g. SERVER_PORT maps to
# the server.port property), and start-https.bat reads ORBION_KEYSTORE_PASSWORD.
#
# The ".env" file you create is git-ignored — never commit real secrets.

# Password for the HTTPS keystore (orbion.p12) used in voice/HTTPS mode.
# Used by start-https.bat (keytool) and application-https.properties.
# Change this from the default before any non-local use.
ORBION_KEYSTORE_PASSWORD=changeme

# HTTP port for the default (non-HTTPS) profile. Optional — defaults to 8080.
SERVER_PORT=8080
